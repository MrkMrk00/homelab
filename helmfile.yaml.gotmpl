repositories:
  - name: argo
    url: https://argoproj.github.io/argo-helm
---
releases:
  - name: argocd
    namespace: argocd
    createNamespace: true
    chart: argo/argo-cd
    version: 9.4.17
    values:
      - global:
          domain: argocd.cluster.local
        server:
          ingress:
            enabled: true
            ingressClassName: traefik
            hostname: argocd.cluster.local

